#!/usr/bin/env bash
set -euo pipefail

branch_name="$(git branch --show-current)"

if [[ -z "$branch_name" ]]; then
  exit 0
fi

upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"

if [[ -n "$upstream_ref" ]]; then
  git push --quiet
else
  git push --quiet --set-upstream origin "$branch_name"
fi
